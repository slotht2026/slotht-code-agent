{
  "name": "slotht-code-agent",
  "version": "0.1.0",
  "description": "自主编程 Agent 系统 — 基于 Ralph 循环 + GitNexus 知识图谱 + Interview 需求澄清",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "slotht": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli/index.js",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "clean": "rm -rf dist/",
    "slotht": "tsx src/cli/index.ts"
  },
  "keywords": [
    "ai-agent",
    "code-generation",
    "ralph-loop",
    "gitnexus",
    "autonomous-coding"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "pino": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
